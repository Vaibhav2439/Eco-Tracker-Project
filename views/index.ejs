<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>EcoTrack – Calculate Footprint</title>
    <link rel="stylesheet" href="/css/public.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .nav a[href="/carbon-calculator"] {
            color: var(--green);
            font-weight: 600;
            position: relative;
        }
        
        .nav a[href="/carbon-calculator"]::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 2px;
            background: var(--green);
            border-radius: 2px;
        }
        
        /* Cool dropdown styling */
        .select-wrapper {
            position: relative;
            margin-bottom: 25px;
            transition: all 0.3s ease;
        }
        
        .select-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent1);
            z-index: 2;
            font-size: 18px;
            text-shadow: 0 0 10px rgba(74, 222, 128, 0.5);
            transition: all 0.3s ease;
        }
        
        .select-wrapper select {
            padding-left: 45px;
            margin-bottom: 0;
            appearance: none;
            cursor: pointer;
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.8), rgba(15, 23, 42, 0.9));
            border: 2px solid rgba(74, 222, 128, 0.2);
            transition: all 0.3s ease;
            font-weight: 500;
            letter-spacing: 0.3px;
        }
        
        .select-wrapper select:hover {
            border-color: var(--accent1);
            box-shadow: 0 0 15px rgba(74, 222, 128, 0.3);
            transform: translateY(-2px);
        }
        
        .select-wrapper select:focus {
            border-color: var(--accent1);
            box-shadow: 0 0 20px rgba(74, 222, 128, 0.4);
            outline: none;
        }
        
        /* Custom dropdown arrow */
        .select-wrapper::after {
            content: '\f078';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent1);
            font-size: 14px;
            pointer-events: none;
            opacity: 0.7;
            transition: all 0.3s ease;
        }
        
        .select-wrapper:hover::after {
            opacity: 1;
            transform: translateY(-50%) rotate(180deg);
        }
        
        /* Cool input styling */
        input {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.8), rgba(15, 23, 42, 0.9));
            border: 2px solid rgba(74, 222, 128, 0.2);
            transition: all 0.3s ease;
            font-weight: 500;
        }
        
        input:hover {
            border-color: var(--accent1);
            box-shadow: 0 0 15px rgba(74, 222, 128, 0.3);
            transform: translateY(-2px);
        }
        
        input:focus {
            border-color: var(--accent1);
            box-shadow: 0 0 20px rgba(74, 222, 128, 0.4);
        }
        
        /* Quantity input with unit selector */
        .quantity-container {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }
        
        .quantity-input-wrapper {
            position: relative;
            flex: 2;
        }
        
        .quantity-input-wrapper input {
            width: 100%;
            padding-right: 10px;
        }
        
        .unit-select-wrapper {
            position: relative;
            flex: 1;
        }
        
        .unit-select-wrapper select {
            width: 100%;
            padding-left: 35px;
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.8), rgba(15, 23, 42, 0.9));
            border: 2px solid rgba(74, 222, 128, 0.2);
            border-radius: 10px;
            color: white;
            font-size: 15px;
            height: 52px;
            cursor: pointer;
            appearance: none;
        }
        
        .unit-select-wrapper i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent1);
            z-index: 2;
            font-size: 16px;
        }
        
        .unit-select-wrapper::after {
            content: '\f078';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent1);
            font-size: 12px;
            pointer-events: none;
        }
        
        /* Food option icons in dropdown */
        select option {
            padding: 12px;
            font-size: 15px;
            display: flex;
            align-items: center;
            background: #1e293b;
            color: white;
        }
        
        /* Glow button enhancement */
        .glow-btn {
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        
        .glow-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s ease;
            z-index: -1;
        }
        
        .glow-btn:hover::before {
            left: 100%;
        }
        
        /* Food icon colors */
        .food-icon-dairy { color: #f1c40f; }
        .food-icon-plant { color: #2ecc71; }
        .food-icon-chicken { color: #e67e22; }
        .food-icon-packaged { color: #95a5a6; }
        .food-icon-beverages { color: #3498db; }
        
        /* Info tooltip */
        .info-tooltip {
            color: #b0c4d9;
            font-size: 12px;
            margin-top: -15px;
            margin-bottom: 15px;
            display: block;
            font-style: italic;
        }
    </style>
</head>
<body>

<%- include("partials/navbar") %>

<section class="hero">
    <h1 class="hero-title">Know Your Carbon Footprint</h1>
    <p class="hero-sub">Track. Reduce. Improve.</p>
</section>

<form action="/calculate" method="POST" class="big-card fade-in">
    <h2 class="form-title">Enter Your Daily Activity</h2>

    <label>🚗 Travel Type</label>
    <div class="select-wrapper">
        <i class="fas fa-car"></i>
        <select name="travelType" required>
            <option value="" disabled selected>Select travel mode</option>
            <option value="car">🚗 Car</option>
            <option value="bus">🚌 Bus</option>
            <option value="bike">🚲 Bike</option>
            <option value="walk">🚶 Walk</option>
        </select>
    </div>

    <label>📏 Distance Travelled (km)</label>
    <input type="number" name="distance" placeholder="e.g., 15" step="0.1" min="0" value="10" required>

    <label>⚡ Electricity Used (kWh)</label>
    <input type="number" name="electricity" placeholder="e.g., 7.5" step="0.1" min="0" value="5" required>

    <label>🍖 Food Type</label>
    <div class="select-wrapper">
        <i class="fas fa-utensils food-icon-dairy"></i>
        <select name="foodType" id="foodType" required>
            <option value="" disabled selected>Select food type</option>
            <option value="dairy">🥛 Dairy Products (Milk, Cheese, Yogurt)</option>
            <option value="plant">🌱 Plant-Based Food (Vegetables, Fruits, Grains)</option>
            <option value="chicken">🍗 Chicken & Poultry</option>
            <option value="packaged">📦 Packaged Food (Snacks, Ready meals)</option>
            <option value="beverages">🥤 Beverages (Soda, Juice, Coffee)</option>
        </select>
    </div>

    <label>⚖️ Quantity</label>
    <div class="quantity-container">
        <div class="quantity-input-wrapper">
            <input type="number" name="foodQuantity" id="foodQuantity" placeholder="e.g., 0.5" step="0.1" min="0" value="0.5" required>
        </div>
        <div class="unit-select-wrapper">
            <i class="fas fa-weight-scale" id="unitIcon"></i>
            <select name="foodUnit" id="foodUnit">
                <option value="kg">kg</option>
                <option value="litres">litres</option>
            </select>
        </div>
    </div>
    <span class="info-tooltip" id="unitTooltip">Enter the amount you consume daily</span>

    <button type="submit" class="glow-btn">
        <i class="fas fa-calculator"></i> Calculate Footprint
    </button>
</form>

<script>
    // Update unit based on food type selection
    document.getElementById('foodType').addEventListener('change', function() {
        const foodType = this.value;
        const foodUnit = document.getElementById('foodUnit');
        const unitIcon = document.getElementById('unitIcon');
        const unitTooltip = document.getElementById('unitTooltip');
        
        if (foodType === 'beverages') {
            foodUnit.value = 'litres';
            unitIcon.className = 'fas fa-mug-hot';
            unitTooltip.textContent = 'Enter the amount in litres you consume daily';
        } else {
            foodUnit.value = 'kg';
            unitIcon.className = 'fas fa-weight-scale';
            unitTooltip.textContent = 'Enter the amount in kg you consume daily';
        }
    });
    
    // Add cool animation to form fields
    document.querySelectorAll('input, select').forEach(field => {
        field.addEventListener('focus', function() {
            this.closest('.select-wrapper, .quantity-input-wrapper, .unit-select-wrapper')?.style.transform = 'scale(1.02)';
        });
        
        field.addEventListener('blur', function() {
            this.closest('.select-wrapper, .quantity-input-wrapper, .unit-select-wrapper')?.style.transform = 'scale(1)';
        });
    });
    
    // Set default values
    window.addEventListener('load', function() {
        document.getElementById('foodQuantity').value = '0.5';
    });
</script>

<script src="/js/theme.js"></script>
<script src="/js/main.js"></script>
</body>
</html>