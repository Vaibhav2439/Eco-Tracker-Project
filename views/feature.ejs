<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EcoTrack – Core Features</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('navbar') %>

  <section class="features-section">
    <div class="features-container">

      <h2 class="section-title">Core Features</h2>
      <p class="section-subtitle">
        Everything you need to kickstart your eco-journey with EcoTrack.
      </p>

      <div class="features-grid">

        <!-- Card 1 -->
        <div class="feature-card">
          <div class="icon-circle">
            <i class="fa-solid fa-leaf"></i>
          </div>
          <h3>Activity Tracking</h3>
          <p>
            Log your daily eco-friendly actions—walking, recycling, or
            reducing energy use—and see your impact grow.
          </p>
          <a href="/activity-tracking" class="feature-link">Explore Feature</a>
        </div>

        <!-- Card 2 -->
        <div class="feature-card">
          <div class="icon-circle">
            <i class="fa-solid fa-shoe-prints"></i>
          </div>
          <h3>Carbon Footprint Calculator</h3>
          <p>
            Measure your carbon emissions with our AI-powered tool
            and get personalized tips to reduce them.
          </p>
          <a href="#" class="feature-link">Explore Feature</a>
        </div>

        <!-- Card 3 -->
        <div class="feature-card">
          <div class="icon-circle">
            <i class="fa-solid fa-trophy"></i>
          </div>
          <h3>Gamified Challenges</h3>
          <p>
            Take on weekly eco-challenges, earn points, and compete
            on the leaderboard to become an eco-champion.
          </p>
          <a href="#" class="feature-link">Explore Feature</a>
        </div>

        <!-- Card 4 -->
        <div class="feature-card">
          <div class="icon-circle">
            <i class="fa-solid fa-users"></i>
          </div>
          <h3>Community Hub</h3>
          <p>
            Join a global network of eco-warriors, share tips,
            and inspire each other to live sustainably.
          </p>
        </div>

        <!-- Card 5 -->
        <div class="feature-card">
          <div class="icon-circle">
            <i class="fa-solid fa-globe"></i>
          </div>
          <h3>3D Earth View</h3>
          <p>
            Heatmap showcasing eco-friendly habits adopted across
            different regions.
          </p>
        </div>

        <!-- Card 6 -->
        <div class="feature-card">
          <div class="icon-circle">
            <i class="fa-solid fa-bag-shopping"></i>
          </div>
          <h3>Carbon Offset Market</h3>
          <p>
            Offset your carbon footprint by trading credits in our
            eco-friendly market, supporting global sustainability.
          </p>
        </div>

      </div>
    </div>
  </section>

</body>
</html>
